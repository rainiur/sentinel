# Copy to .env and adjust if any port collides with software on your machine.
# Compose reads this file automatically when you run commands from infra/docker/.

# Host ports (left side of docker port mappings) — defaults avoid common local services
# (5432, 6379, 8080, 3000, 9000, 9001).
SENTINEL_POSTGRES_PORT=30432
SENTINEL_REDIS_PORT=30379
SENTINEL_MINIO_API_PORT=30900
SENTINEL_MINIO_CONSOLE_PORT=30901
SENTINEL_API_PORT=30880
SENTINEL_WEB_PORT=30700

# Optional: full URL the browser uses to reach the API (defaults to http://localhost:<SENTINEL_API_PORT>).
# Set this if the API is not on localhost (e.g. SENTINEL_BROWSER_API_URL=http://192.168.1.10:30880).
# SENTINEL_BROWSER_API_URL=

# MCP: host file mounted at /etc/sentinel/mcp.json in API and worker (Cursor-style JSON with mcpServers).
# Default uses the repo example; copy to config/mcp.json (gitignored) and point here for real servers.
SENTINEL_MCP_HOST_FILE=../../config/mcp.example.json
# In-container path is fixed; override only if you use a custom image layout:
# SENTINEL_MCP_CONFIG=/etc/sentinel/mcp.json

# Optional: comma-separated mcpServers keys to hide from GET /api/mcp/servers (summary/UI; MCP client must match).
# SENTINEL_MCP_DISABLED_SERVERS=playwright,ssh-mcp

# Optional: max /api/* requests per client IP per rolling 60s window (0 = disabled). In-process only.
# SENTINEL_RATE_LIMIT_RPM=120

# Worker job queue (optional; defaults match worker code): SENTINEL_JOB_QUEUE, SENTINEL_WORKER_BRPOP_TIMEOUT

# Optional API auth (pass through to api if set in this .env):
# SENTINEL_REQUIRE_AUTH=true
# SENTINEL_JWT_SECRET=change-me-use-long-random-secret

# Optional: emergency read-only API (blocks mutating methods on /api/*).
# SENTINEL_API_WRITES_DISABLED=true
