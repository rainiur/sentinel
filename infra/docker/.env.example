# Copy to .env and adjust if any port collides with software on your machine.
# Compose reads this file automatically when you run commands from infra/docker/.

# Host ports (left side of docker port mappings) — defaults avoid common local services
# (5432, 6379, 8080, 3000, 9000, 9001).
SENTINEL_POSTGRES_PORT=30432
SENTINEL_REDIS_PORT=30379
SENTINEL_MINIO_API_PORT=30900
SENTINEL_MINIO_CONSOLE_PORT=30901
SENTINEL_API_PORT=30880
SENTINEL_WEB_PORT=30700

# Optional: full URL the browser uses to reach the API (defaults to http://localhost:<SENTINEL_API_PORT>).
# Set this if the API is not on localhost (e.g. SENTINEL_BROWSER_API_URL=http://192.168.1.10:30880).
# SENTINEL_BROWSER_API_URL=

# MCP: path to a JSON file with a top-level "mcpServers" object (same shape as Cursor's mcp.json).
# Copy config/mcp.example.json to config/mcp.json (gitignored) and set paths/URLs per server.
# In Docker, mount that file into the container and set SENTINEL_MCP_CONFIG to the in-container path.
# SENTINEL_MCP_CONFIG=/etc/sentinel/mcp.json

# Optional API auth (pass through to api/worker if you add these to compose environment):
# SENTINEL_REQUIRE_AUTH=true
# SENTINEL_JWT_SECRET=change-me-use-long-random-secret
