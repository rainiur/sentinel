# When databases run via infra/docker compose, use host-mapped ports (see infra/docker/.env.example).
DATABASE_URL=postgresql+psycopg://sentinel:sentinel@localhost:30432/sentinel
REDIS_URL=redis://localhost:30379/0

# Job queue (Redis LIST). Producer: LPUSH JSON objects, e.g.
#   redis-cli -u "$REDIS_URL" LPUSH sentinel:jobs '{"type":"noop","job_id":"manual-1"}'
# SENTINEL_JOB_QUEUE=sentinel:jobs
# SENTINEL_WORKER_BRPOP_TIMEOUT=5
# SENTINEL_WORKER_HEARTBEAT_SEC=30

# MCP (planned): same Cursor-style mcpServers JSON as API (see config/mcp.example.json).
# SENTINEL_MCP_CONFIG=/absolute/path/to/mcp.json
