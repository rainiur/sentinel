# Optional: omit or leave empty to run the API in in-memory mode (local tests / quick dev).
#
# If Postgres/Redis/MinIO run via infra/docker compose, use the host-mapped ports from
# infra/docker/.env.example (defaults: Postgres 30432, Redis 30379, MinIO 30900).
DATABASE_URL=postgresql+psycopg://sentinel:sentinel@localhost:30432/sentinel

REDIS_URL=redis://localhost:30379/0
S3_ENDPOINT=http://localhost:30900
S3_BUCKET=sentinel-artifacts
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
