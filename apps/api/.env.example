# Optional: omit or leave empty to run the API in in-memory mode (local tests / quick dev).
#
# If Postgres/Redis/MinIO run via infra/docker compose, use the host-mapped ports from
# infra/docker/.env.example (defaults: Postgres 30432, Redis 30379, MinIO 30900).
DATABASE_URL=postgresql+psycopg://sentinel:sentinel@localhost:30432/sentinel

REDIS_URL=redis://localhost:30379/0
S3_ENDPOINT=http://localhost:30900
S3_BUCKET=sentinel-artifacts
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
# Presigned PUT expiry for evidence uploads (seconds; 60–604800). Default 900 if unset.
# S3_PRESIGN_EXPIRES_SECONDS=900
# Optional; default us-east-1 (works with MinIO).
# S3_REGION=us-east-1

# Authentication (optional). When SENTINEL_REQUIRE_AUTH=true, set a strong SENTINEL_JWT_SECRET
# and send Authorization: Bearer <JWT> (HS256, claims: sub, exp, role=analyst|admin).
# SENTINEL_REQUIRE_AUTH=
# SENTINEL_JWT_SECRET=

# MCP: JSON config path — Cursor-style file with "mcpServers" (see config/mcp.example.json).
# GET /api/mcp/servers returns names + transport only (no secrets).
# SENTINEL_MCP_CONFIG=/absolute/path/to/mcp.json
# Hide named mcpServers from GET /api/mcp/servers (comma-separated keys). Does not block tool calls until client exists.
# SENTINEL_MCP_DISABLED_SERVERS=

# Maintenance: block POST/PUT/PATCH/DELETE on /api/* (reads still work).
# SENTINEL_API_WRITES_DISABLED=true

# Rate limit: max requests per client IP per rolling 60s on /api/* only (0 = off). Single-process buckets.
# SENTINEL_RATE_LIMIT_RPM=0
# Behind a trusted reverse proxy, use first X-Forwarded-For hop (spoofable if proxy not trusted):
# SENTINEL_TRUST_X_FORWARDED_FOR=true
